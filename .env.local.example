# Configuración de PostgreSQL para desarrollo local
# NOTA: Este archivo NO debe ser commiteado. Está en .gitignore.

# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos

# Opción 1: Con contraseña (desarrollo local)
# DATABASE_URL="postgresql://abiel:abiel_dev_password@localhost:5432/abiel_dev"

# Opción 2: Sin contraseña (local con usuario del SO)
# DATABASE_URL="postgresql://postgres@localhost:5432/abiel_dev"

# Opción 3: Con socket Unix (máquinas Linux/Mac)
# DATABASE_URL="postgresql://postgres@/tmp/.s.PGSQL.5432/abiel_dev"

# Reemplaza los valores según tu instalación de PostgreSQL
